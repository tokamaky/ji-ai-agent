server {
    listen ${PORT};
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    resolver 8.8.8.8 1.1.1.1 valid=300s;

    location /api/ {
        # 后端公网 URL：https://backend-production-bab0.up.railway.app
        set $backend ${BACKEND_INTERNAL_URL};
        proxy_pass $backend/api/;

        proxy_http_version 1.1;
        # 关键：HTTPS 反代必须设置正确的 Host 头（用 backend 的域名，不是前端的）
        proxy_set_header Host backend-production-bab0.up.railway.app;
        proxy_ssl_server_name on;
        proxy_ssl_name backend-production-bab0.up.railway.app;

        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
        proxy_cache off;
        proxy_set_header Connection '';
        chunked_transfer_encoding off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_connect_timeout 60s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}